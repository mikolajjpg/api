{% extends "index.html" %}
{% block title %}Biblioteczka - Dodaj Książkę{% endblock %}

{% block content %}
<h2>Nowa książka do przeczytania</h2>
<form method="post">
    <input type="text" name="title" placeholder="Tytuł książki..." value="{{ title or '' }}" required />
    <button type="submit">Zapisz na półkę</button>
</form>
<br>
<a href="{{ url_for('list_books') }}">⬅ Wróć do listy</a>
{% endblock %}
